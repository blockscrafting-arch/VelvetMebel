# === Бот MAX ===
MAX_BOT_TOKEN=ваш_токен_бота

# === Google Sheets ===
GOOGLE_SHEET_ID=id_гугл_таблицы
GOOGLE_CREDENTIALS_FILE=credentials.json

# === Настройки ===
FEEDBACK_DELAY_HOURS=24

# === Чат техподдержки (кнопка «Нет», кнопка «Написать в техподдержку» в главном меню) ===
SUPPORT_CHAT_LINK=https://max.ru/join/...

# === Веб-админка (отдельный процесс: python -m admin.main или uvicorn) ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=задайте_надёжный_пароль
# ADMIN_HOST=0.0.0.0
# ADMIN_PORT=8000

# === Модели мебели (Velvet Mebel): названия захардкожены в config.py ===
# Комод, Обувница, Обувница с ящиком

# === Видеоинструкции (ссылки) ===
MODEL_1_VIDEO=https://example.com/video1
MODEL_2_VIDEO=https://example.com/video2
MODEL_3_VIDEO=https://example.com/video3
